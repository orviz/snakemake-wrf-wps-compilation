# workflow/Snakefile
import os

configfile: "config/config.yaml"

# Dynamic variables from config.yaml
INSTALL_ROOT = config["install_root"]
WPS_VERSION = config["wps_version"]
EESSI_INIT = config["eessi_init_script"]
WRF_MODULE = config["eessi_wrf_module"]
WRF_DIR = config["eessi_wrf_dir"]
WPS_CONFIGURE_OPTION = config["wps_configure_option"]

# Jasper and WPS source directories
JASPER_VERSION = config.get("jasper_version", "1.900.1")
JASPER_DOWNLOAD_URL = config.get(
    "jasper_download_url",
    f"https://www2.mmm.ucar.edu/wrf/OnLineTutorial/compile_tutorial/tar_files/jasper-{JASPER_VERSION}.tar.gz"
)
JASPER_DIR = os.path.join(INSTALL_ROOT, f"jasper-{JASPER_VERSION}")
WPS_SRC_DIR = os.path.join(workflow.basedir, "..", "src", "WPS")

rule all:
    input:
        f"logs/wps_installation_{WPS_VERSION}.done"

# -----------------------------------------------------------------------------
# RULE 1: Jasper installation from source
# -----------------------------------------------------------------------------
rule install_jasper:
    """Download, configure and compile Jasper."""
    output:
        lib = os.path.join(JASPER_DIR, "lib", "libjasper.a"),
        inc = os.path.join(JASPER_DIR, "include", "jasper", "jasper.h")
    log:
        "logs/install_jasper.log"
    params:
        download_url = JASPER_DOWNLOAD_URL,
        version = JASPER_VERSION,
        prefix = JASPER_DIR
    shadow: "minimal"
    shell:
        """
        exec >> {log} 2>&1 # Redirect all output to log file

        wget --quiet {params.download_url}
        tar -xvzf jasper-{params.version}.tar.gz
        cd jasper-{params.version}
        
	# CFLAGS added for potential conflicts among modern gcc compiler versions and Jasper
	# -fcommon: Resuelve las definiciones duplicadas de variables globales (el error que prevenimos antes).
	# -Wno-error=implicit-function-declaration: Le ordena a tu flamante GCC 15 que degrade las declaraciones implícitas de vuelta a simples advertencias (warnings), permitiendo que la compilación de Jasper finalice con éxito.
	# -Wno-error=incompatible-pointer-types: En sistemas Linux modernos de 64 bits, el tipo interno de Jasper jpc_fix_t se evalúa como un entero de tipo largo de 64 bits (long int), mientras que otras funciones de la librería esperan punteros a enteros estándar de 32 bits (int). Este flag rebaja la severidad del compilador.
        export CFLAGS="-fcommon -Wno-error=implicit-function-declaration -Wno-error=incompatible-pointer-types"
        ./configure --prefix={params.prefix}
        make
        make install
        """

# -----------------------------------------------------------------------------
# RULE 2: Cloning the official WPS repository
# -----------------------------------------------------------------------------
rule clone_wps:
    """Clone the specific tag of the WPS model."""
    output:
        config_script = os.path.join(WPS_SRC_DIR, "configure")
    log:
        "logs/clone_wps.log"
    params:
        src_dir = WPS_SRC_DIR,
        version = WPS_VERSION
    shell:
        """
        exec > {log} 2>&1
        mkdir -p "$(dirname {params.src_dir})"
        git clone https://github.com/wrf-model/WPS.git {params.src_dir}
        cd {params.src_dir}
        git checkout {params.version}
        """

# -----------------------------------------------------------------------------
# RULE 3: WPS configuration injecting the EESSI environment
# -----------------------------------------------------------------------------
rule configure_wps:
    """Run the WPS ./configure script loading the CVMFS (EESSI) variables."""
    input:
        config_script = os.path.join(WPS_SRC_DIR, "configure"),
        jasper_lib = os.path.join(JASPER_DIR, "lib", "libjasper.a")
    output:
        make_config = os.path.join(WPS_SRC_DIR, "configure.wps")
    log:
        "logs/configure_wps.log"
    params:
        eessi_init = EESSI_INIT,
        wrf_module = WRF_MODULE,
        jasper_dir = JASPER_DIR,
        wrf_dir = WRF_DIR,
        src_dir = WPS_SRC_DIR,
        config_option = WPS_CONFIGURE_OPTION
    shell:
        """
        # Clean sub-shell inheriting PATH for compiler calls:q
        env -i HOME=$HOME TERM=$TERM PATH=/usr/bin:/bin:/usr/local/bin:$PATH /usr/bin/bash -c "
            exec >> {log} 2>&1

            # 1. Load EESSI and NetCDF dependencies from the toolchain
            source {params.eessi_init}
            module load {params.wrf_module}
            
            export LD_LIBRARY_PATH=$$NETCDFF/lib:$$NETCDF_C/lib:$${{LD_LIBRARY_PATH:-}}
            export JASPERLIB={params.jasper_dir}/lib
            export JASPERINC={params.jasper_dir}/include
            export WRF_DIR={params.wrf_dir}
            
            # 2. Configue WPS with selected options (GRIB2 enabled)
            cd {params.src_dir}
            ./clean -a > /dev/null 2>&1
            echo "{params.config_option}" | ./configure
        "
        """

# -----------------------------------------------------------------------------
# RULE 4: Final compilation of the geographic and meteorological binaries
# -----------------------------------------------------------------------------
rule compile_wps:
    """Launch the WPS make and check the success of the 3 main executables."""
    input:
        make_config = os.path.join(WPS_SRC_DIR, "configure.wps")
    output:
        geogrid = os.path.join(WPS_SRC_DIR, "geogrid.exe"),
        ungrib = os.path.join(WPS_SRC_DIR, "ungrib.exe"),
        metgrid = os.path.join(WPS_SRC_DIR, "metgrid.exe"),
        final_flag = f"logs/wps_installation_{WPS_VERSION}.done"
    log:
        "logs/compile_wps.log"
    params:
        eessi_init = EESSI_INIT,
        wrf_module = WRF_MODULE,
        jasper_dir = JASPER_DIR,
        wrf_dir = WRF_DIR,
        src_dir = WPS_SRC_DIR
    threads: 8
    shell:
        """
        PIXI_BIN_DIR=$(pwd)/.pixi/envs/default/bin

        # Clean sub-shell inheriting PATH for compiler calls
        env -i HOME=$HOME TERM=$TERM PATH=/usr/bin:/bin:/usr/local/bin:$PATH /usr/bin/bash -c "
            exec >> {log} 2>&1

            source {params.eessi_init}
            module load {params.wrf_module}

            # OpenBLAS can cause issues with WPS compilation, so we set it to use a single thread
            export OPENBLAS_NUM_THREADS=1

            export LD_LIBRARY_PATH=$$NETCDFF/lib:$$NETCDF_C/lib:{params.jasper_dir}/lib:$${{LD_LIBRARY_PATH:-}}
            export JASPERLIB={params.jasper_dir}/lib
            export JASPERINC={params.jasper_dir}/include
            export WRF_DIR={params.wrf_dir}

            cd {params.src_dir}
            tcsh ./compile
            
            # Validate the physical success and sign the pipeline
            if [ -f "geogrid.exe" ] && [ -f "ungrib.exe" ] && [ -f "metgrid.exe" ]; then
                touch ../../{output.final_flag}
            else
                echo "Error: Compilation failed. Check logs/compile_wps.log" >&2
                exit 1
            fi
        "
        """
