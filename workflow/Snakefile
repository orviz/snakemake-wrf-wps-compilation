# workflow/Snakefile
import os

configfile: "config/config.yaml"

EESSI_INIT  = config["eessi_init_script"]
WPS_VER     = config["wps_version"]
WRF_VER     = config["wrf_version"]
TC_SUFFIX   = config["toolchain_suffix"]

rule all:
    input:
        "bin/WPS_compilation.done",
        "bin/WRF_compilation.done"

# =========================================================================
# REGLA 1: Auditoría Dinámica del Estado Central de EESSI via eb -S
# =========================================================================
rule audit_eessi_status:
    output:
        json_report = "audit/{software}_status.json"
    params:
        eessi_init = EESSI_INIT,
        version    = lambda wildcards: WPS_VER if wildcards.software == "WPS" else WRF_VER,
        tc_suffix  = TC_SUFFIX
    threads: 1
    shell:
        """
        workflow/audit_eessi.sh \
            '{params.eessi_init}' \
            '{wildcards.software}' \
            '{params.version}' \
            '{params.tc_suffix}' \
            '{output.json_report}'
        """

# =========================================================================
# REGLA 2: Compilación Inteligente Automática (Modo Oficial / Fallback Local)
# =========================================================================
rule compile_software_via_eb:
    input:
        status_json = "audit/{software}_status.json"
    output:
        marker = "bin/{software}_compilation.done"
    params:
        eessi_init = EESSI_INIT,
        # Ruta de la receta local de contingencia en tu carpeta config/ por si hiciera falta
        local_recipe = lambda wildcards: os.path.abspath(f"config/{wildcards.software}-{WPS_VER if wildcards.software == 'WPS' else WRF_VER}{TC_SUFFIX}.eb"),
        marker_dir   = os.path.abspath("bin"),
        marker_abs   = lambda wildcards, output: os.path.abspath(output.marker)
    threads: 8
    shell:
        """
        workflow/compile_eb.sh \
            '{params.eessi_init}' \
            '{input.status_json}' \
            '{params.local_recipe}' \
            '{params.marker_dir}' \
            '{params.marker_abs}'
        """
