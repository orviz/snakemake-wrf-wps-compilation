import os
from jinja2 import Template

# Load the user-defined configuration file
configfile: "config/config.yaml"

# Required parameters for WPS compilation
required_keys = ["wps_git_repo", "wps_git_tag", "wps_git_sha256"]
for key in required_keys:
    if key not in config or not config[key]:
        raise KeyError(
            f"\n❌ [Snakemake Error]: Required parameter '{key}' is not defined or empty in config.yaml.\n"
            f"For security and reproducibility, you must specify the exact repository, tag, and checksum."
        )

# Retrieve pipeline parameters from the configuration file
WPS_EB_TEMPLATE = config.get("wps_easyconfig_path", "config/WPS-4.6.0-custom.eb.j2")
WPS_REPO   = config["wps_git_repo"]
WPS_TAG    = config["wps_git_tag"]
WPS_SHA256 = config["wps_git_sha256"]
GENERATED_EB = "config/WPS-generated.eb"
EESSI_INIT = config.get("eessi_init_script", "/cvmfs/software.eessi.io/versions/latest/init/bash")

rule all:
    input:
        "bin/wps_compilation.done"

rule render_wps_easyconfig:
    """Inject parameters into EB config."""
    input:
        eb_template = WPS_EB_TEMPLATE
    output:
        eb_real = GENERATED_EB
    params:
        repo   = WPS_REPO,
        tag    = WPS_TAG,
        sha256 = WPS_SHA256
    resources:
        runtime = 2,
        mem_mb = 1024
    run:
        print(f"[Snakemake] Generating customized EasyConfig: {output.eb_real}")

        with open(input.eb_template, "r") as f:
            template_content = f.read()

        template = Template(template_content)
        rendered_content = template.render(
            wps_git_repo=params.repo,
            wps_git_tag=params.tag,
            wps_git_sha256=params.sha256
        )

        with open(output.eb_real, "w") as f:
            f.write(rendered_content)

rule compile_wps_hpc:
    """Launch EB compilation via EESSI."""
    input:
        eb_recipe = GENERATED_EB
    output:
        marker = "bin/wps_compilation.done"
    params:
        repo = WPS_REPO,
        tag  = WPS_TAG
    shell:
        """
        echo "[Snakemake] Targeting HPC Environment via EESSI..."

        # 1. Initialize EESSI stack via the parameterized initialization script
        set +u
        if [ -f "{EESSI_INIT}" ]; then
            source {EESSI_INIT}
        else
            echo "[Snakemake Error] EESSI initialization script not found at: {EESSI_INIT}"
            exit 1
        fi

        # 2. Load the official extension tool which safely configures EasyBuild on top of EESSI
        module load EESSI-extend
        set -u

        echo "[Snakemake] Building WPS from Repo: {params.repo} ({params.tag})"

        # 3. Invoke EasyBuild. It will natively clone the code and handle all dependencies
        eb {input.eb_recipe} --robot --local-var-naming-check=warn

        # Generate the execution proof marker token to let Snakemake satisfy downstream dependencies
        mkdir -p $(dirname {output.marker})
        touch {output.marker}
        """