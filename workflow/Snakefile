# workflow/Snakefile
import os

configfile: "config/config.yaml"

EESSI_INIT  = config["eessi_init_script"]
WPS_VER     = config["wps_version"]
WRF_VER     = config["wrf_version"]
TC_SUFFIX   = config["toolchain_suffix"]

rule all:
    input:
        "bin/ungrib.exe",
        "bin/wrf.exe"

# =========================================================================
# RULE 1: Dynamic Discovery of Central EESSI Repository State via eb -S
# =========================================================================
rule audit_eessi_status:
    output:
        json_report = "audit/{software}_status.json"
    params:
        eessi_init = EESSI_INIT,
        version    = lambda wildcards: WPS_VER if wildcards.software == "WPS" else WRF_VER,
        tc_suffix  = TC_SUFFIX
    threads: 1
    shell:
        """
        workflow/audit_eessi.sh \
            '{params.eessi_init}' \
            '{wildcards.software}' \
            '{params.version}' \
            '{params.tc_suffix}' \
            '{output.json_report}'
        """

# =========================================================================
# RULE 2: Intelligent Compilation and Dynamic Local Symlink Generation
# =========================================================================
rule compile_software_via_eb:
    input:
        # Static file constraints preventing Python-to-Snakemake wildcard collisions
        wps_json = "audit/WPS_status.json",
        wrf_json = "audit/WRF_status.json"
    output:
        # Real victory condition: exact binary path mapped locally inside the repository
        real_binary = "bin/{executable}.exe"
    wildcard_constraints:
        executable = "ungrib|wrf"
    params:
        eessi_init   = EESSI_INIT,
        sw_name      = lambda wildcards: "WPS" if wildcards.executable == "ungrib" else "WRF",
        local_recipe = lambda wildcards: os.path.abspath(f"config/{'WPS' if wildcards.executable == 'ungrib' else 'WRF'}-{WPS_VER if wildcards.executable == 'ungrib' else WRF_VER}{TC_SUFFIX}.eb"),
        marker_dir   = os.path.abspath("bin"),
        marker_abs   = lambda wildcards, output: os.path.abspath(output.real_binary)
    threads: 8
    shell:
        """
        # Dynamically inject the appropriate JSON metadata footprint into the compiler
        STATUS_JSON="audit/WPS_status.json"
        if [ "{wildcards.executable}" == "wrf" ]; then
            STATUS_JSON="audit/WRF_status.json"
        fi

        workflow/compile_eb.sh \
            '{params.eessi_init}' \
            "$STATUS_JSON" \
            '{params.local_recipe}' \
            '{params.marker_dir}' \
            '{params.marker_abs}'
        """
